                  "yes"
                ]
              ],
              "asyncAwait": [
                [
                  "top"
                ]
              ],
              "script": [
                "// Change this variable to modify the number of generated colors\n\nvar l = 10000,\n    high = 1000;\n\nvar i = 0,\n    a = Array(l);\n\nfunction rnd(n) {\n    return Math.floor(Math.random()*n);\n}\n\nvar o;\nfor(; i < l; i++) {\n    o = {\n        r: rnd(256),\n        g: rnd(256),\n        b: rnd(256),\n        a: Math.random()\n    };\n    o.color = \"rgba(\"+o.r+\",\"+o.g+\",\"+o.b+\",\"+o.a+\")\";\n    o.colorC = {type:'color',value:o.color};\n    o._highlight = [rnd(high)];\n    a[i] = o;\n}\n\nAPI.createData('bigArray', a);"
              ]
            }
          ],
          "libs": [
            [
              {}
            ]
          ],

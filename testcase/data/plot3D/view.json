    {
      "url": "modules/types/client_interaction/code_executor/",
      "configuration": {
        "sections": {},
        "groups": {
          "group": [
            {
              "display": [
                [
                  "editor",
                  "buttons"
                ]
              ],
              "execOnLoad": [
                [
                  "yes"
                ]
              ],
              "asyncAwait": [
                [
                  "top"
                ]
              ],
              "script": [
                "const value = {\n    points: 200,\n    colors: 5,\n    highlights: 5,\n    minSize: 1,\n    maxSize: 2\n};\n\nfunction generateRandomArray(n, min, max) {\n    var result = [];\n    for(var i=0; i<n; i++) {\n      result.push(Math.random()*(max-min) + min);\n    }\n    return result;\n}\n\nfunction generateRandomColors(d, n) {\n    var arr = new Array(d);\n    arr = _(arr).map(function(val, key) {\n        return key/d;\n    }).map(function(val) {\n        return 'hsl(' + val*360 + ',65%,65%)';\n    }).map(function(val) {\n        return chroma(val).hex();    \n    }).value();\n    \n    var result = new Array(n);\n    result = _(result).map(function(val) {\n        return Math.floor(Math.random() * d);\n    }).map(function(val){\n        return arr[val];\n    }).value();\n    return result;\n}\n\nfunction generateRandomFromArray(arr, n) {\n    var x = generateRandomArray(n, 0, arr.length-0.001);\n    x = x.map(function(a) {\n        return arr[Math.floor(a)];\n    }); \n    return x;\n}\n\nvar n = value.points;\nvar x = generateRandomArray(n, 0, 5);\nvar y = generateRandomArray(n, 0, 5);\nvar z = generateRandomArray(n, -0.005, 0.005);\nvar color = generateRandomColors(value.colors, n);\n//var shape = generateRandomFromArray(['sphere', 'tetrahedron'], n);\n\nvar arr = [];\nfor(var i=0; i<value.highlights; i++) {\n    arr.push(i.toString());\n}\nvar highlight = generateRandomFromArray(arr, n);\nvar size = generateRandomArray(n, value.minSize, value.maxSize);\n\n\nvar result = [];\nfor(var i=0; i<n; i++) {\n    result.push({});\n    result[i].x = x[i];\n    result[i].y = y[i];\n    result[i].z = z[i];\n    result[i].color = color[i];\n    result[i].size = size[i];\n    result[i]._highlight = highlight[i];\n}\n\nvar table = _(highlight).uniq().sort().map(function(val) {\n    return {\n        label: val,\n        _highlight: val\n    }\n}).value();\n\nAPI.createData('table', table);\nAPI.createData('test', result);\n"
              ]
            }
          ],
